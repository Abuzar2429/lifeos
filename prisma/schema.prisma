// Prisma Schema for LifeOS Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  isOnboarded   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  preferences      UserPreferences?
  dailyCheckIns    DailyCheckIn[]
  habits           Habit[]
  habitLogs        HabitLog[]
  goals            Goal[]
  journalEntries   JournalEntry[]
  userAchievements UserAchievement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserPreferences {
  id            String   @id @default(cuid())
  userId        String   @unique
  focusAreas    String   @default("[]") // JSON string of selected area names
  topPriorities String   @default("[]") // JSON string of top 3 priorities
  themeMode     String   @default("dark")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyCheckIn {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime // Midnight timestamp for date lookup
  mood           Int      @default(3) // 1-5 rating
  energy         Int      @default(3) // 1-5 rating
  sleepHours     Float    @default(7.0)
  waterGlasses   Int      @default(8)
  workoutMins    Int      @default(0)
  studyHours     Float    @default(0.0)
  readingMins    Int      @default(0)
  reflectionNote String?
  dailyScore     Int      @default(0) // Calculated score 0-100
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Habit {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String   @default("General") // Study, Fitness, Health, Career, Reading, Mindfulness
  frequency   String   @default("DAILY") // DAILY, WEEKDAYS, CUSTOM
  customDays  String?  // JSON array of weekdays if CUSTOM
  targetValue Int      @default(1)
  unit        String?  @default("times")
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@index([userId])
}

model HabitLog {
  id          String   @id @default(cuid())
  habitId     String
  userId      String
  date        DateTime // Midnight timestamp
  completedAt DateTime @default(now())
  status      Boolean  @default(true)
  notes       String?

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([habitId, date])
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?
  category     String   @default("General")
  timeframe    String   @default("MONTHLY") // DAILY, WEEKLY, MONTHLY, YEARLY
  targetValue  Float    @default(100.0)
  currentValue Float    @default(0.0)
  unit         String?  @default("%")
  completed    Boolean  @default(false)
  targetDate   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones GoalMilestone[]

  @@index([userId])
}

model GoalMilestone {
  id        String   @id @default(cuid())
  goalId    String
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id             String   @id @default(cuid())
  userId         String
  title          String
  content        String
  moodTag        String?  // e.g. #mindset, #study, #fitness
  sentimentScore Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags Tag[]

  @@index([userId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  journalEntries JournalEntry[]
}

model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique // e.g., STREAK_7, STUDY_100, PERFECT_WEEK
  title       String
  description String
  icon        String   @default("Trophy")
  category    String   @default("General")
  threshold   Int      @default(1)
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}
